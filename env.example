# ─────────────────────────────────────────────
#  BROKER SELECTION
#  Options: "binance" | "kraken" | "forex"
# ─────────────────────────────────────────────
BROKER=binance

# ─────────────────────────────────────────────
#  ASSET & TIMEFRAMES
# ─────────────────────────────────────────────
# Binance / Kraken:  BTC/USDT, ETH/USDT, SOL/USDT ...
# Forex (OANDA):     EUR_USD, GBP_USD, USD_JPY ...
SYMBOL=BTC/USDT
LTF=1h        # Trading timeframe:  1m 5m 15m 30m 1h 4h 1d
HTF=4h        # Higher timeframe:   always one step above LTF

# ─────────────────────────────────────────────
#  STRATEGY PARAMETERS
# ─────────────────────────────────────────────
EMA_FAST=9
EMA_SLOW=21
ADX_PERIOD=14
ADX_THRESHOLD=25
ATR_PERIOD=14
ATR_SL_MULT=1.5     # Stop loss  = entry ± (1.5 × ATR)
ATR_TP_MULT=2.5     # Take profit = entry ± (2.5 × ATR)

# ─────────────────────────────────────────────
#  RISK & CAPITAL
# ─────────────────────────────────────────────
RISK_PCT=1.0              # % of equity risked per trade
INITIAL_CAPITAL=10000     # Starting capital for backtest ($)
BACKTEST_DAYS=365         # How many days of history to backtest

# ─────────────────────────────────────────────
#  BINANCE CREDENTIALS
# ─────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ─────────────────────────────────────────────
#  KRAKEN CREDENTIALS
# ─────────────────────────────────────────────
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here

# ─────────────────────────────────────────────
#  FOREX / OANDA CREDENTIALS
# ─────────────────────────────────────────────
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ACCOUNT_ID=your_oanda_account_id_here
OANDA_ENVIRONMENT=practice    # "practice" (demo) | "live"
